# ==========================================
# Twitch Configuration
# ==========================================
# Your Twitch bot/account username
TWITCH_USERNAME=your_username

# OAuth token for Twitch authentication
# Get yours at: https://twitchtokengenerator.com/
# Required scopes: chat:read
# Format: oauth:xxxxxxxxxxxxxxxxxx
TWITCH_OAUTH_TOKEN=oauth:your_token_here

# Channel to join (without the # symbol)
TWITCH_CHANNEL=channel_name

# ==========================================
# Kick Configuration
# ==========================================
# Channel to join on Kick
# No authentication needed for reading chat!
KICK_CHANNEL=channel_name

# ==========================================
# Server Configuration
# ==========================================
# Port for the web interface
# Default: 8080
PORT=8080
